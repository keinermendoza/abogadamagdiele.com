---
import Whatsapp from "@components/Whatsapp.astro"
---
<nav>
  <div class="wrapper">
    <div class="logo"><a href="/#inicio">Abogada Magdiele</a></div>

    <input type="radio" name="slider" id="menu-btn">
    <input type="radio" name="slider" id="close-btn">

    <ul class="nav-links">
      <label for="close-btn" class="btn close-btn">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
      </label>
      <li><a class="nav-anchor" href="#sobre-mi">Sobre Mí</a></li>
      <li><a class="nav-anchor" href="#servicios">Servicios</a></li>

      <li><a class="nav-anchor" href="#empezando">Empezando</a></li>
      <li><a class="nav-anchor" href="#resenas">Reseñas</a></li>
      <li><a class="nav-anchor" href="#direccion">Dirección</a></li>
      <li><a class="nav-anchor" href="#respuestas">Respuestas</a></li>
      <li class="primary-btn-container">
        <Whatsapp class="btn-primary">Agendar cita</Whatsapp>
      </li>
    </ul>
    <label for="menu-btn" class="btn menu-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </label>
  </div>
</nav>

<script is:inline>
  const closeRadioBtn = document.getElementById('close-btn');
  document.querySelectorAll('.nav-anchor').forEach(anchor => {
    anchor.onclick = () => closeRadioBtn.checked = true;
  });
</script>

<style lang="scss">

.primary-btn-container {
  display: flex;
  align-items: center;
  
  // sparate primary buttons from all other links
  margin-left: auto;

  .btn-primary {
    line-height: 1.5;
    padding: 10px 24px;
    border-radius: 22px;
    flex-shrink: 0;
    font-size: 1rem;
  }
}

$brakepoint: 85rem;

// adapted from https://codepen.io/fadzrinmadu/pen/bGqrJjB
// root
nav {
  position: fixed;
  z-index: 99;
  width: 100%;
  background-color: rgba(255,255,255,0.9);

  // blur
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  input{
    display: none;
  }
}

.logo a {

  font-size: 24px;
  font-weight: var(--fw-title);
  text-decoration: none;
  color: var(--clr-black);
  @media screen and (max-width: $brakepoint) {font-size:var(--fs-sm);}
}

.wrapper {
  max-width: 95rem;
  margin-inline: auto;
  position: relative;
  padding: 0px 1.5rem;
  height: 70px;
  line-height: 70px;
  display: flex;
  align-items: center;
  justify-content: space-between;

  // separate logo from all other links
  gap:max(5rem, 4.8vw);
}

.nav-links {
  display: inline-flex;
  flex-grow: 1;
  gap: 0.25rem;

  @media screen and (max-width: $brakepoint) {
    position: fixed;
    height: 100vh;
    width: 100%;
    max-width: 350px;
    top: 0;
    left: -100%;
    background-color: var(--clr-white);
    display: block;
    padding: 50px 10px;
    line-height: 50px;
    overflow-y: auto;
    box-shadow: 0px 15px 15px rgba(0,0,0,0.18);
    transition: all 0.3s ease;
  }

  li {
    list-style: none;

    @media screen and (max-width: $brakepoint) {margin: 15px 10px;}

    .nav-anchor {
      color: var(--clr-black);

      text-decoration: none;
      font-size: 18px;
      font-weight: 500;
      padding: 9px 15px;
      border-radius: 5px;
      transition: all 0.3s ease;

      @media screen and (max-width: $brakepoint) {
        padding: 0 20px;
        display: block;
        font-size: 20px;
      }

      &:hover,
      &:focus {
        background: var(--clr-soft-gray) 
      }
    }
  }

}

.btn {
  // font-size: 20px;
  cursor: pointer;
  display: none;
  


  // define button shape
  @media screen and (max-width: $brakepoint) {
    width: fit-content;
    background-color: var(--clr-gray);
    border-radius: 50%;
    display: grid;
    padding: 0.7rem;
    svg {
      width: 1.5rem;
    }
  }

  &.close-btn{
    position: absolute;
    right: 1rem;
    top: 10px;
  }
}

@media screen and (max-width: $brakepoint) {
  #menu-btn:checked ~ .nav-links{
    left: 0%;
  }
  #menu-btn:checked ~ .btn.menu-btn{
    display: none;
  }
  #close-btn:checked ~ .btn.menu-btn{
    display: grid;
  }
}

</style>