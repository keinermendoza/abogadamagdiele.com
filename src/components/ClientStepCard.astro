---
import type { CollectionEntry } from 'astro:content';
interface Props {
  step: CollectionEntry<'clientSteps'>;
}

const {step} = Astro.props;
---

<article>
    <h3>{step.data.title}</h3>
    <div>
    {step.data.text.map(paragraph => 
        <p>{paragraph}</p>
    )}
    </div>
</article>

