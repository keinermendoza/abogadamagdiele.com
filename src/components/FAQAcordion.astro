---
import { getCollection } from "astro:content";

const FAQs = await getCollection('FAQs');
---

<div class="accordion">
    {FAQs.map(({data}) => (
    <div class="accordion-item g-box-shadow">
        <button class="accordion-header">
          <span>{data.question}</span>
          <div class="icon-container">
            <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 10L12 15L17 10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          
        </button>
        <div class="accordion-content">
            {data.text.map(paragraph => <p>{paragraph}</p>)}
        </div>
    </div>  
    )
)}
</div>

<script is:inline>
    document.querySelectorAll('.accordion-header').forEach(button => {
    button.addEventListener('click', () => {
    const accordionItem = button.parentElement;

    // Opcional: Cerrar otros ítems abiertos (estilo "single open")
    document.querySelectorAll('.accordion-item').forEach(item => {
      if (item !== accordionItem) {
        item.classList.remove('active');
      }
    });

    // Alternar la clase active en el ítem clickeado
    accordionItem.classList.toggle('active');
  });
});
</script>

<style lang="scss">

  .accordion {
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}

.accordion-header {
  background-color: var(--clr-white);
  font-size: var(--fs-md);
  font-weight: var(--fw-title);
  font-family: var(--ff-body);
  text-align: left;
  width: 100%;
  border: none;
  cursor: pointer;
  font-size: 1rem;
  font-weight: bold;
  transition: background-color 0.125s ease;
  outline: none;

  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.5rem;
  border-radius: 24px;
  padding: 10px 18px;

  @media (min-width:68rem) {
    border-radius: 40px;
  }

  .icon-container {
      display: grid;
      place-content: center;
      padding: 6px;
      width: 36px;
      border-radius: 100%;
      background-color: var(--clr-primary);
      color: var(--clr-white);
      flex-shrink: 0;
    .icon {
      width: 100%;
      aspect-ratio: 1;
    }
  }

}

.accordion-header:hover {
  background-color: var(--clr-gray);
}

/* El contenedor del contenido oculto */
.accordion-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
  background: white;
}

.accordion-content p {
  padding: 15px;
  margin: 0;
}

/* Clase activa que aplicaremos con JS */
.accordion-item.active .accordion-content {
  max-height: 200px; /* Un valor mayor al contenido esperado */
}

.accordion-item.active .accordion-header {
  background: #e0e0e0;
}
</style>