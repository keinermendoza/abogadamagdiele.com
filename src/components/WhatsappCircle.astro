---
import {encodeMessage} from "@assets/whatsapp"


const message = "Hola, vi su sitio web y me gustaría contratar uno de sus servicios. ¿Podemos hablar?."
const whatsappLink = encodeMessage(message);

---

<p class="fixed-btn">
  <a href={whatsappLink} class='circle-whatsapp-btn' target="_blank" aria-label="Escríbeme por whatsapp" >
    <svg class="size-8" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
        <path fill="currentColor" fill-rule="evenodd" d="M12 4a8 8 0 0 0-6.895 12.06l.569.718-.697 2.359 2.32-.648.379.243A8 8 0 1 0 12 4ZM2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10a9.96 9.96 0 0 1-5.016-1.347l-4.948 1.382 1.426-4.829-.006-.007-.033-.055A9.958 9.958 0 0 1 2 12Z" clip-rule="evenodd"/>
        <path fill="currentColor" d="M16.735 13.492c-.038-.018-1.497-.736-1.756-.83a1.008 1.008 0 0 0-.34-.075c-.196 0-.362.098-.49.291-.146.217-.587.732-.723.886-.018.02-.042.045-.057.045-.013 0-.239-.093-.307-.123-1.564-.68-2.751-2.313-2.914-2.589-.023-.04-.024-.057-.024-.057.005-.021.058-.074.085-.101.08-.079.166-.182.249-.283l.117-.14c.121-.14.175-.25.237-.375l.033-.066a.68.68 0 0 0-.02-.64c-.034-.069-.65-1.555-.715-1.711-.158-.377-.366-.552-.655-.552-.027 0 0 0-.112.005-.137.005-.883.104-1.213.311-.35.22-.94.924-.94 2.16 0 1.112.705 2.162 1.008 2.561l.041.06c1.161 1.695 2.608 2.951 4.074 3.537 1.412.564 2.081.63 2.461.63.16 0 .288-.013.4-.024l.072-.007c.488-.043 1.56-.599 1.804-1.276.192-.534.243-1.117.115-1.329-.088-.144-.239-.216-.43-.308Z"/>
    </svg>
  </a>
</p>

<style lang="scss">
.fixed-btn {
  // --from-border: 1rem;
  // position: fixed;
  // bottom: var(--from-border);
  // right: var(--from-border);
  // z-index: 20;
  transition: transform;
  position: relative;
  
  &:hover {
    transform: scale(1.1);
  }
    // @media (min-width: 68rem) {
    //         --from-border: 2rem;
    //     }


}

.circle-whatsapp-btn {
  display: grid;
  place-content: center;
  padding: 1rem;
  border-radius: 50%;
  color: var(--clr-white) ;
  background-color: var(--clr-primary) ;
  &::before {
    content: "";
    position: absolute;
    width: 110%; 
    height: 110%;
    top: -5%;
    left: -5%;
    border-radius: 50%;
    border: 3px solid var(--clr-gold);
    animation: waveExpand 3s infinite ease-in-out;
  }

  @keyframes waveExpand {
    0% {
      transform: scale(1);
      opacity: 0.9;
    }
    100% {
      transform: scale(1.3); 
      opacity: 0;
    }
  }
} 


</style>