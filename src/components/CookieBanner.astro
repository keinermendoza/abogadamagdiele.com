<div id="cookie-banner" class="cookie-container">
    <div class="cookie-content">
        <p>
            Utilizamos cookies propias y de terceros para analizar el tráfico de nuestro sitio web (Google Analytics). 
            Al hacer clic en "Aceptar", consientes el uso de estas tecnologías. Puedes rechazar las cookies si lo prefieres.
        </p>
        <div class="cookie-buttons">
            <button id="cookie-reject" class="btn btn-secondary">Rechazar</button>
            <button id="cookie-accept" class="btn btn-primary">Aceptar</button>
        </div>
    </div>
</div>

<style>
.cookie-container {
    position: fixed;
    bottom: 20px;
    left: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    justify-content: center;
}

/* Caja del banner */
.cookie-content {
    background-color: var(--clr-white);
    color: var(--clr-black);
    padding: 20px 30px;
    box-shadow: rgba(100, 100, 111, 0.2) 0px 7px 29px 0px;
    border-radius: 12px;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    border: 1px solid #eee;
}

@media (min-width: 768px) {
    .cookie-content {
        flex-direction: row;
        text-align: left;
    }
}

/* Texto */
.cookie-content p {
    margin: 0;
    line-height: 1.5;
}

/* Botones */
.cookie-buttons {
    display: flex;
    gap: 10px;
    white-space: nowrap;
}

.btn {
    padding: 10px 20px;
    border: 1px solid var(--clr-black);
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    transition: background 0.3s ease;
}

.btn-primary {
    background-color:  #0056b3;
    color: white;
}

.btn-primary:hover {
    background-color: var(--clr-primary);
}

.btn-secondary {
    background-color: var(--clr-white);
    color: #6c757d;
    border: 1px solid #ddd;
}

.btn-secondary:hover {
    background-color: #e2e6ea;
}

</style>

<script is:inline>
document.addEventListener('astro:after-swap', setupCookieBanner);
document.addEventListener('DOMContentLoaded', setupCookieBanner);
// asumes GTM is loaded
function gtag(){window.dataLayer.push(arguments);}

function setupCookieBanner() {

    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const rejectBtn = document.getElementById('cookie-reject');

    if (!banner || !acceptBtn || !rejectBtn) return;

    // Evita listeners duplicados
    acceptBtn.onclick = null;
    rejectBtn.onclick = null;

    if (localStorage.getItem('cookies-accepted') === null) {
        banner.style.display = 'flex';
    } else {
        banner.style.display = 'none';
    }

    acceptBtn.onclick = () => {
        localStorage.setItem('cookies-accepted', 'true');
        banner.style.display = 'none';
        // defined in Layout.astro
        gtag('consent', 'update', window.myConsents_granted);
    };

    rejectBtn.onclick = () => {
        localStorage.setItem('cookies-accepted', 'false');
        banner.style.display = 'none';
        // defined in Layout.astro
        gtag('consent', 'update', window.myConsents_rejected);

    };
}
</script>
