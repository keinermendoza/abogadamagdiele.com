---
import { render, type CollectionEntry } from 'astro:content';
// import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  service: CollectionEntry<'keyServices'>;
}

const {service} = Astro.props;
const {Content} = await render(service);
---

<article class="key-service-card" id={service.id}>
    <div class="icon-container">
        <Image
          class="icon" 
          src={service.data.picture} 
          alt=""
          width={22}
          height={25}
          />
    </div>
    <h3 class="title">{service.data.title}</h3>
    <p>{service.data.description}</p>
    <footer>
      <a class="general-btn-secondary-color btn" href="#">Ver Requisitos</a>
      <a class="general-btn-primary-color btn" href="#">Agendar Cita</a>      
    </footer>
  </article>

<div style="display: none;">
  <Content />
</div>

<style lang="scss">
  .key-service-card {
    background-color: var(--clr-white);
    padding: 1.5rem 1.25rem;
    border-radius: 2rem;
    display: grid;
    gap: 1rem;
    max-width: 40rem;
    margin-inline: auto;

    // https://getcssscan.com/css-box-shadow-examples 75 airbnb
    box-shadow: rgba(0, 0, 0, 0.08) 0px 4px 12px;
    

    @media (min-width:68rem) {
      padding: 2.5rem;
    }
    .title {
      font-size: var(--fs-md);
      @media (min-width:68rem) {
        font-size: var(--fs-lg);
      }
    }

    footer {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      align-items: end;
      flex-grow: 1;
    }
  }

  .icon-container {
      background-color: var(--clr-black);
      width: 3.5rem;
      aspect-ratio: 1;
      border-radius: 100%;
      padding: 1rem;
      display: grid;
      place-content: center;

      .icon {
        width: 100%;
      }
    }


.btn {
    font-size: 0.875rem;
    padding: 10px 16px;
    border-radius: 2em;
  @media (min-width:68rem) {
    font-size: 1rem;
    padding: 14px 22px;
  }

}


</style>